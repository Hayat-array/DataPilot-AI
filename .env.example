# Flask Settings
FLASK_ENV=development
SECRET_KEY=generate-a-strong-secret-key-for-prod
HOST=0.0.0.0
PORT=5000
VALIDATE_ENV_ON_START=true

# Databases
MONGO_URI=mongodb://localhost:27017/datapilot_db
MONGO_DB_NAME=datapilot_db

# LLM Providers (At least one API key is required)
# OPENAI_API_KEY=your-openai-api-key
# GROQ_API_KEY=your-groq-api-key
# GOOGLE_API_KEY=your-google-api-key

GROQ_API_KEY=your-groq-api-key-here
UPSTASH_VECTOR_REST_URL=your-upstash-vector-rest-url
UPSTASH_VECTOR_REST_TOKEN=your-upstash-vector-rest-token
GOOGLE_API_KEY=your-google-api-key-here

# RAG & Embeddings
UPSTASH_URL=your-upstash-url
UPSTASH_TOKEN=your-upstash-token
